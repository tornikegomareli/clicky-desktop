# Clicky Desktop — API Keys
# Copy this file to .env and fill in your keys.
# For the release version, keys will be entered via the settings UI.

# Required for voice transcription (https://www.assemblyai.com)
ASSEMBLYAI_API_KEY=

# Required for vision + response generation (https://www.anthropic.com)
ANTHROPIC_API_KEY=

# Required for text-to-speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
