# Clicky Desktop — API Keys
# Copy this file to .env and fill in your keys.
# For the release version, keys will be entered via the settings UI.

# Required for voice transcription (https://www.assemblyai.com)
ASSEMBLYAI_API_KEY=

# LLM provider — set ONE of these (Anthropic preferred, OpenAI as alternative)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Required for text-to-speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=

# Optional: Cloudflare Worker proxy URL (alternative to direct API keys)
# CLICKY_WORKER_URL=https://your-worker.your-subdomain.workers.dev
